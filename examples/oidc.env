# OIDC authentication example
# See docs/guides/authentication.md for setup instructions

IMAGE_GEN_MCP_BASE_URL=https://mcp.example.com
IMAGE_GEN_MCP_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
IMAGE_GEN_MCP_OIDC_CLIENT_ID=mcp-client
IMAGE_GEN_MCP_OIDC_CLIENT_SECRET=your-client-secret
IMAGE_GEN_MCP_OIDC_JWT_SIGNING_KEY=your-signing-key   # openssl rand -hex 32
IMAGE_GEN_MCP_READ_ONLY=false
