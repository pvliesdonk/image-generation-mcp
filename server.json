{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.pvliesdonk/image-gen-mcp",
  "title": "Image Gen MCP Server",
  "description": "FastMCP server template — replace this with your description",
  "version": "0.1.0",
  "repository": {
    "url": "https://github.com/pvliesdonk/image-gen-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "image-gen-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "oci",
      "identifier": "ghcr.io/pvliesdonk/image-gen-mcp:0.1.0",
      "transport": {
        "type": "streamable-http",
        "url": "http://localhost:{--port}/mcp"
      },
      "packageArguments": [
        {
          "type": "named",
          "name": "--port",
          "default": 8000,
          "description": "Port for the HTTP transport"
        }
      ]
    }
  ]
}
