# Image Generation MCP environment variables (copy to .env and fill in).

# --- Server ---
# IMAGE_GENERATION_MCP_SERVER_NAME=image-generation-mcp
# IMAGE_GENERATION_MCP_TRANSPORT=stdio   # stdio | http | sse
# IMAGE_GENERATION_MCP_HOST=127.0.0.1
# IMAGE_GENERATION_MCP_PORT=8000
# IMAGE_GENERATION_MCP_HTTP_PATH=/mcp
# IMAGE_GENERATION_MCP_BASE_URL=https://mcp.example.com

# --- Auth (pick one flavor) ---
# IMAGE_GENERATION_MCP_BEARER_TOKEN=<secret>

# IMAGE_GENERATION_MCP_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
# IMAGE_GENERATION_MCP_OIDC_CLIENT_ID=<client-id>
# IMAGE_GENERATION_MCP_OIDC_CLIENT_SECRET=<client-secret>
# IMAGE_GENERATION_MCP_OIDC_AUDIENCE=
# IMAGE_GENERATION_MCP_OIDC_REQUIRED_SCOPES=openid
# IMAGE_GENERATION_MCP_OIDC_JWT_SIGNING_KEY=<hex-string>

# --- Domain (image generation) ---
# IMAGE_GENERATION_MCP_READ_ONLY=true
# IMAGE_GENERATION_MCP_SCRATCH_DIR=~/.image-generation-mcp/images
# IMAGE_GENERATION_MCP_STYLES_DIR=~/.image-generation-mcp/styles
# IMAGE_GENERATION_MCP_DEFAULT_PROVIDER=auto      # auto | openai | gemini | sd_webui | placeholder
# IMAGE_GENERATION_MCP_PAID_PROVIDERS=openai      # comma-separated
# IMAGE_GENERATION_MCP_TRANSFORM_CACHE_SIZE=64
# IMAGE_GENERATION_MCP_OPENAI_API_KEY=sk-...
# IMAGE_GENERATION_MCP_GOOGLE_API_KEY=AIza...
# IMAGE_GENERATION_MCP_SD_WEBUI_HOST=http://localhost:7860
# IMAGE_GENERATION_MCP_SD_WEBUI_MODEL=
# IMAGE_GENERATION_MCP_EVENT_STORE_URL=file:///data/state/events
