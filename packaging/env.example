# Image Generation MCP Server — environment configuration
# Copy to /etc/image-generation-mcp/env and edit.
# See https://pvliesdonk.github.io/image-generation-mcp/configuration/

# --- Core ---

# When true, write-tagged tools (generate_image) are hidden.
# Set to false to enable image generation.
#IMAGE_GENERATION_MCP_READ_ONLY=true

# Directory for saved generated images.
# Default: ~/.image-generation-mcp/images/ (resolves to /var/lib/image-generation-mcp/images/ for systemd)
#IMAGE_GENERATION_MCP_SCRATCH_DIR=/var/lib/image-generation-mcp/images

# Default provider: auto (keyword-based), openai, a1111, or placeholder.
#IMAGE_GENERATION_MCP_DEFAULT_PROVIDER=auto

# --- Providers ---

# OpenAI API key — enables gpt-image-1 and dall-e-3.
#IMAGE_GENERATION_MCP_OPENAI_API_KEY=sk-...

# Automatic1111 WebUI base URL — enables Stable Diffusion.
#IMAGE_GENERATION_MCP_A1111_HOST=http://localhost:7860

# A1111 checkpoint name for preset detection.
#IMAGE_GENERATION_MCP_A1111_MODEL=

# --- Authentication (HTTP transport only) ---

# Static bearer token.
#IMAGE_GENERATION_MCP_BEARER_TOKEN=

# OIDC — all four must be set to enable.
#IMAGE_GENERATION_MCP_BASE_URL=https://mcp.example.com
#IMAGE_GENERATION_MCP_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
#IMAGE_GENERATION_MCP_OIDC_CLIENT_ID=image-generation-mcp
#IMAGE_GENERATION_MCP_OIDC_CLIENT_SECRET=

# Stable JWT signing key — required on Linux to persist sessions across restarts.
# Generate: openssl rand -hex 32
#IMAGE_GENERATION_MCP_OIDC_JWT_SIGNING_KEY=

# --- Server ---

# Log level: DEBUG, INFO, WARNING, ERROR.
#IMAGE_GENERATION_MCP_LOG_LEVEL=INFO
